# Copy to .env and fill in your credentials to run the examples.
#
# Recommended: a single account API key (starts with "sk-"). Create one at
# https://my.webhookrelay.com/tokens
RELAY_API_KEY=sk-...

# Classic access token pair (key + secret) — alternative to RELAY_API_KEY.
# RELAY_KEY=your-token-key
# RELAY_SECRET=your-token-secret
